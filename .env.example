# App
APP_NAME=Grocery Distribution API
APP_ENV=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost,https://myapp.com

# Database (asyncpg DSN for SQLAlchemy async engine)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/grocery_db

# JWT
JWT_SECRET=change-this-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
